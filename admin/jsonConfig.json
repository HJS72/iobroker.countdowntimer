{
  "type": "panel",
  "items": {
    "timers": {
      "type": "table",
      "label": "Timer",
      "help": "Konfiguration mehrerer Countdown-Timer",
      "items": [
        {
          "type": "text",
          "attr": "timerName",
          "label": "Timer Name"
        },
        {
          "type": "checkbox",
          "attr": "timerActive",
          "label": "Aktiv"
        },
        {
          "type": "state",
          "attr": "triggerDP",
          "label": "Trigger Datenpunkt"
        },
        {
          "type": "select",
          "attr": "triggerType",
          "label": "Trigger Typ",
          "options": [
            { "label": "Button", "value": "button" },
            { "label": "Switch", "value": "switch" }
          ]
        },
        {
          "type": "number",
          "attr": "duration",
          "label": "Dauer (Minuten)",
          "min": 1
        }
      ]
    }
  }
}

